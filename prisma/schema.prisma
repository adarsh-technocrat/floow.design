generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id           String        @id @default(cuid())
  name         String        @default("Untitled Project")
  chatSessions ChatSession[]
  frames       Frame[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model ChatSession {
  id        String   @id @default(cuid())
  projectId String
  agentId   String   @default("default")
  project   Project  @relation(fields: [projectId], references: [id])
  messages  Json     @default("[]")
  updatedAt DateTime @updatedAt

  @@unique([projectId, agentId])
}

model Frame {
  id        String   @id
  projectId String   @default("default")
  project   Project  @relation(fields: [projectId], references: [id])
  label     String   @default("Screen")
  left      Int      @default(0)
  top       Int      @default(0)
  html      String   @db.Text
  updatedAt DateTime @updatedAt
}
