generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AuthProvider {
  GOOGLE
  GITHUB
  APPLE
  EMAIL
}

enum PlanType {
  FREE
  LITE
  STARTER
  PRO
  TEAM
}

model User {
  id                   String        @id
  email                String?       @unique
  displayName          String?
  photoURL             String?
  phoneNumber          String?
  provider             AuthProvider?
  stripeCustomerId     String?       @unique
  stripeSubscriptionId String?
  plan                 PlanType      @default(FREE)
  billingInterval      String?
  seats                Int           @default(1)
  credits              Int           @default(0)
  creditsResetAt       DateTime?
  chatSessions         ChatSession[]
  creditLogs           CreditLog[]
  apiKeys              ApiKey[]
  themes               Theme[]
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@index([stripeSubscriptionId])
}

model CreditLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String
  amount    Int
  balance   Int
  projectId String?
  meta      String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, amount, createdAt])
}

model Project {
  id           String        @id @default(cuid())
  name         String        @default("Untitled Project")
  thumbnail    String?       @db.Text
  isTemplate   Boolean       @default(false)
  templateTag  String?
  trashedAt    DateTime?
  chatSessions ChatSession[]
  frames       Frame[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([trashedAt, isTemplate])
  @@index([updatedAt])
  @@index([isTemplate])
}

model ChatSession {
  id        String   @id @default(cuid())
  projectId String
  userId    String
  project   Project  @relation(fields: [projectId], references: [id])
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Json     @default("[]")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
}

model Frame {
  id        String   @id
  projectId String   @default("default")
  project   Project  @relation(fields: [projectId], references: [id])
  themeId   String?
  theme     Theme?   @relation(fields: [themeId], references: [id])
  label     String   @default("Screen")
  left      Int      @default(0)
  top       Int      @default(0)
  html      String   @db.Text
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([projectId, updatedAt])
  @@index([themeId])
}

model Theme {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String   @default("Default")
  variables Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  frames    Frame[]

  @@index([userId])
}

model ApiKey {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  key       String    @unique
  lastUsed  DateTime?
  revoked   Boolean   @default(false)
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  @@index([userId])
}

model BlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String   @db.Text
  content     String   @db.Text
  tldr        String?  @db.Text
  category    String
  tags        String[]
  author      String
  authorRole  String?
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([published, createdAt(sort: Desc)])
}
