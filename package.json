{
  "name": "floow-design",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "blog:publish": "dotenv -e .env.local -- tsx scripts/publish-blog.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepare": "husky"
  },
  "dependencies": {
    "@ai-sdk/google-vertex": "^4.0.61",
    "@ai-sdk/react": "^3.0.93",
    "@dicebear/collection": "^9.4.2",
    "@dicebear/core": "^9.4.2",
    "@google/genai": "^1.42.0",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@mux/mux-player-react": "^3.11.7",
    "@next/mdx": "^16.2.1",
    "@number-flow/react": "^0.6.0",
    "@prisma/client": "^6.19.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@reduxjs/toolkit": "^2.11.2",
    "@stripe/stripe-js": "^8.11.0",
    "@vercel/blob": "^2.3.1",
    "ai": "^6.0.90",
    "axios": "^1.13.6",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "firebase": "^12.11.0",
    "firebase-admin": "^13.7.0",
    "framer-motion": "^12.38.0",
    "gray-matter": "^4.0.3",
    "html2canvas": "^1.4.1",
    "js-beautify": "^1.15.4",
    "lucide-react": "^0.574.0",
    "next": "16.1.6",
    "next-mdx-remote": "^6.0.0",
    "next-themes": "^0.4.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.0.0",
    "react-redux": "^9.2.0",
    "reading-time": "^1.5.0",
    "recharts": "^3.8.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-pretty-code": "^0.14.3",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.9.4",
    "shiki": "^3.23.0",
    "sonner": "^2.0.7",
    "stripe": "^20.4.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,mjs,cjs,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,html,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@storybook/addon-essentials": "8.6.14",
    "@storybook/addon-themes": "8.6.14",
    "@storybook/blocks": "8.6.14",
    "@storybook/react": "8.6.14",
    "@storybook/react-vite": "8.6.14",
    "@storybook/test": "8.6.14",
    "@tailwindcss/postcss": "^4",
    "@types/js-beautify": "^1.14.3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/turndown": "^5.0.6",
    "dotenv-cli": "^7.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "prettier": "^3.8.1",
    "prisma": "^6.19.2",
    "storybook": "8.6.14",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "turndown": "^7.2.2",
    "typescript": "^5"
  }
}
